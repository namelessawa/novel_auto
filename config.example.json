{
  "_note": "如果主项目 ../.env 中已设置 LLM_PROVIDER, 本文件中的 llm 段会被忽略 (作为兜底)。要切换提供商, 优先编辑主项目 .env 的 LLM_PROVIDER (deepseek|mimo|custom)。",
  "llm": {
    "api_key": "sk-your-deepseek-api-key-here",
    "base_url": "https://api.deepseek.com",
    "model": "deepseek-chat",
    "_alternative_providers_example": {
      "mimo": {
        "api_key": "your-mimo-key",
        "base_url": "https://token-plan-cn.xiaomimimo.com/v1",
        "model": "mimo-chat"
      }
    }
  },
  "memory": {
    "working_memory_size": 3,
    "summary_merge_threshold": 10,
    "section_summary_length": 50
  },
  "vector_db": {
    "persist_dir": "./data/chroma",
    "top_k": 5
  },
  "knowledge_graph": {
    "snapshot_dir": "./data/snapshots"
  },
  "pipeline": {
    "max_validation_retries": 3,
    "max_chapter_retries": 2
  },
  "server": {
    "host": "0.0.0.0",
    "backend_port": 8762,
    "frontend_port": 3143,
    "cors_origins": ["https://your-domain.com"]
  },
  "auth": {
    "_note": "v2.26 — 邮箱 OTP 注册 + 可选密码登录。jwt_secret 必填且建议 >= 64 字符随机串; 留空时系统启动会注入随机 secret, 但每次重启会导致已签发的 token 立即失效。",
    "enabled": true,
    "jwt_secret": "REPLACE-ME-WITH-A-LONG-RANDOM-STRING-AT-LEAST-64-CHARS",
    "jwt_algorithm": "HS256",
    "jwt_ttl_days": 7,
    "otp_ttl_seconds": 300,
    "otp_send_per_ip_per_hour": 3,
    "otp_send_per_email_per_hour": 3,
    "otp_verify_per_ip_per_15min": 10,
    "password_login_per_ip_per_15min": 5,
    "password_login_per_email_per_15min": 5,
    "ephemeral_ttl_hours": 24,
    "cleanup_interval_seconds": 3600
  },
  "smtp": {
    "_note": "用于发送 OTP 验证码。腾讯企业邮箱: smtp.exmail.qq.com:465 (SSL)。授权码不是登录密码。from_addr 必须与 user 同域名同账号。",
    "host": "smtp.exmail.qq.com",
    "port": 465,
    "use_ssl": true,
    "user": "noreply@your-company.com",
    "password": "REPLACE-WITH-MAIL-AUTHORIZATION-CODE",
    "from_addr": "noreply@your-company.com",
    "from_name": "NovelAuto"
  }
}
