.env
.venv/
__pycache__/
*.pyc
*.pyo
.idea/
.qwen/
node_modules/
*.log

# Phase 5+: 本地 LLM 凭据/暂存 (绝不 commit)
coding.txt

# Test / lint caches
.coverage
.pytest_cache/
.ruff_cache/
htmlcov/

# Claude session state
.claude/
.claude_design_cache/

# 本地配置 / 运行时数据(含密钥)
config.json
backend/data/
backend/.venv/
backend/.pytest_cache/
backend/.ruff_cache/
frontend/dist/
frontend/.env.production

# 进程启动时若 config.json 用了相对路径,会在工作目录自动创建这些
/data/
/results/
/temp/

# 归档目录里 v1.x 运行数据
old/results/
old/temp/
old/memory_system/long_term_memory_db/
old/memory_system/entity_snapshots/

# Windows / git-bash crash dumps
bash.exe.stackdump
**/bash.exe.stackdump

# Markdown 文档默认不追踪, 但 docs/ 下全部允许 (避免 phase plan / verdict 被静默丢)
*.md
!/README.md
!/CHANGELOG.md
!/structure.md
!deploy/**/README.md
!docs/**/*.md

# Phase 5+ matrix bench per-cell 产物 (~200 文件, 个别 cell 可重跑复现).
# 必须在 !docs/**/*.md 之后, last-match-wins 才能盖过上面的全 un-ignore.
docs/iter/bench-matrix-*.json
docs/iter/bench-matrix-*.md
docs/iter/bench-m_*.json
docs/iter/bench-m_*.md

# Review 复盘临时产物 (extract_findings.py 的输出, 不入 git)
scripts/findings.json
scripts/findings.err
