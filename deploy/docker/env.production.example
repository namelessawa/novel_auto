# ============================================================
# Docker 部署 .env 模板 — 拷到项目根 (与 docker-compose.yml 上两级) 后填
#   cp deploy/docker/env.production.example .env
#   # 然后 nano .env 填实际值
#
# 两个容器(backend / cloudflared)共用同一个 .env 文件;
# Python 进程只读自己关心的变量, cloudflared 只读 CLOUDFLARED_TOKEN, 互不干扰。
# ============================================================

# ---------- 运行时 (后端) ----------
# 容器内 0.0.0.0 没问题(网络隔离), 公网入口由 cloudflared 容器把流量送进来
AGENT_HOST=0.0.0.0
AGENT_PORT=8762
AGENT_LOG_LEVEL=info

# ---------- LLM 提供商 ----------
LLM_PROVIDER=deepseek
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

DEEPSEEK_API_KEY=sk-PUT-YOUR-REAL-KEY-HERE
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 小米 MiMo (可选)
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-chat

# 任意 OpenAI 兼容端点 (可选)
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=

# ---------- Cloudflare Tunnel ----------
# 在 https://one.dash.cloudflare.com/ → Networks → Tunnels → Create a tunnel
# 选 Cloudflared, 取个名字(如 novel-auto), 创建后选 "Docker" 安装方式,
# 它会给出一条 `docker run ... --token eyJhI...` 命令, 把 token 部分拷过来。
CLOUDFLARED_TOKEN=eyJhI...PUT-YOUR-REAL-TOKEN-HERE

# ---------- 记忆系统 ----------
SLIDING_WINDOW_MAX_TOKENS=2500
CONTINUITY_THRESHOLD=80.0
SUMMARY_MAX_LENGTH=100

# ---------- 日志 ----------
LOG_LEVEL=INFO
VERBOSE_LOG=false

# ============================================================
# 镜像源 (build-time + cloudflared image)
# ============================================================
# docker-compose.yml 已写好默认值, 都走国内源, 一般不用改。
# 这里把它们列出来是为了在默认源挂掉 / 想走官方源时, 解开注释覆盖。
#
# 默认: daocloud(docker hub) + 清华(PyPI / apt)
# 备选 docker hub 镜像源(任选其一, 拉不动就换下一个):
#   docker.m.daocloud.io
#   docker.1panel.live
#   dockerhub.icu
#   hub.uuuadc.top
#   docker.unsee.tech
# 走回官方 docker.io: 把 REGISTRY= 留空, CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
#
# PyPI 备选:
#   https://pypi.tuna.tsinghua.edu.cn/simple    清华
#   https://mirrors.aliyun.com/pypi/simple/     阿里云
#   https://pypi.mirrors.ustc.edu.cn/simple/    中科大
#   https://pypi.org/simple                     官方
#
# apt 备选 (debian 12 bookworm):
#   mirrors.tuna.tsinghua.edu.cn   清华
#   mirrors.aliyun.com             阿里云
#   mirrors.ustc.edu.cn            中科大
#   deb.debian.org                 官方

# REGISTRY=docker.m.daocloud.io
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# APT_MIRROR=mirrors.tuna.tsinghua.edu.cn
# CLOUDFLARED_IMAGE=docker.m.daocloud.io/cloudflare/cloudflared:latest
