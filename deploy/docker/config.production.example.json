{
  "_note": "Docker 部署的 config.json 模板。bind mount 到容器 /app/config.json:ro。改完容器内代码下次 _load_config() 会读到新值,无需 rebuild。cors_origins 必须列 Vercel 域名。",
  "llm": {
    "api_key": "",
    "base_url": "https://api.deepseek.com",
    "model": "deepseek-chat",
    "provider": "deepseek"
  },
  "memory": {
    "working_memory_size": 3,
    "summary_merge_threshold": 10,
    "section_summary_length": 50
  },
  "vector_db": {
    "persist_dir": "./backend/data/chroma",
    "top_k": 5
  },
  "knowledge_graph": {
    "snapshot_dir": "./backend/data/snapshots"
  },
  "pipeline": {
    "max_validation_retries": 3,
    "max_chapter_retries": 2
  },
  "server": {
    "host": "0.0.0.0",
    "backend_port": 8762,
    "frontend_port": 3143,
    "cors_origins": [
      "https://novel.your-domain.com",
      "https://novel-frontend.vercel.app"
    ]
  }
}
