# ============================================================
# Vercel 前端环境变量 — 在 Vercel 项目 Settings → Environment Variables 配置
# 不要 commit 真实值
# ============================================================

# 后端 API 基地址 — Cloudflare Tunnel 暴露的 hostname
# 不能带末尾斜杠, 不能带 /api 后缀(代码会自动拼)
VITE_API_BASE=https://api.novel.your-domain.com

# 静态资源前缀 — Vercel 走根路径
VITE_BASE_PATH=/

# 可选: 部署环境标识 (展示在 UI 角落)
# VITE_DEPLOY_ENV=production
