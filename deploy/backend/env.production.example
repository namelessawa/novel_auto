# ============================================================
# 无限小说生成系统 — 生产 .env 模板
# 部署到 /opt/novel_auto/.env, 权限设为 chmod 600
# 业务上和项目根 .env.example 同源, 此文件突出 *生产* 必填项
# ============================================================

# ---------- 运行时 ----------
# 监听地址: 强烈推荐 127.0.0.1, 由 cloudflared 内部转发, 不暴露公网
AGENT_HOST=127.0.0.1
AGENT_PORT=8762
AGENT_LOG_LEVEL=info

# ---------- LLM 提供商 ----------
# deepseek | mimo | custom
LLM_PROVIDER=deepseek
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# DeepSeek (默认)
DEEPSEEK_API_KEY=sk-PUT-YOUR-REAL-KEY-HERE
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# MiMo (小米, 可选)
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-chat

# 自定义 OpenAI 兼容端点 (可选)
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=

# ---------- 多媒体 (可选, 默认关) ----------
ENABLE_MULTIMEDIA=false
DASHSCOPE_API_KEY=

# ---------- 记忆系统 ----------
SLIDING_WINDOW_MAX_TOKENS=2500
CONTINUITY_THRESHOLD=80.0
SUMMARY_MAX_LENGTH=100

# ---------- 日志 ----------
LOG_LEVEL=INFO
VERBOSE_LOG=false
