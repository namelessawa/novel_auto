{
  "_note": "生产用 config.json — 关键修改: server.cors_origins 必须含 Vercel 域名; server.host 锁 127.0.0.1; llm.api_key 留空让 .env 接管",
  "llm": {
    "api_key": "",
    "base_url": "https://api.deepseek.com",
    "model": "deepseek-chat",
    "provider": "deepseek"
  },
  "memory": {
    "working_memory_size": 3,
    "summary_merge_threshold": 10,
    "section_summary_length": 50
  },
  "vector_db": {
    "persist_dir": "./backend/data/chroma",
    "top_k": 5
  },
  "knowledge_graph": {
    "snapshot_dir": "./backend/data/snapshots"
  },
  "pipeline": {
    "max_validation_retries": 3,
    "max_chapter_retries": 2
  },
  "server": {
    "host": "127.0.0.1",
    "backend_port": 8762,
    "frontend_port": 3143,
    "cors_origins": [
      "https://novel.your-domain.com",
      "https://novel-frontend.vercel.app"
    ]
  }
}
