# ============================================
# 无限小说生成系统 - 环境变量配置
# ============================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入您的实际 API 密钥
# 3. 根据需要调整其他配置
# ============================================

# --------------------------------------------
# LLM 提供商选择
# --------------------------------------------
# 可选值：deepseek | mimo | custom
# 各提供商的 API Key / Base URL / Model 在下面各自分段填写
LLM_PROVIDER=deepseek

# 通用参数（所有提供商共享，可被覆盖）
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# --------------------------------------------
# DeepSeek API 配置
# --------------------------------------------
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
# 向后兼容字段（如果填了，会覆盖 LLM_* 通用参数）
DEEPSEEK_MAX_TOKENS=8192
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_TIMEOUT=120

# --------------------------------------------
# MiMo (小米) API 配置
# --------------------------------------------
# 申请地址：参考小米官方文档；OpenAI 兼容协议
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-chat

# --------------------------------------------
# 自定义 (OpenAI 兼容) 端点
# --------------------------------------------
# 任何 OpenAI 兼容的 base_url 都可以接进来
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=

# --------------------------------------------
# DashScope API 配置（可选，用于图片生成）
# --------------------------------------------
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_MODEL=qwen-image-2.0
DASHSCOPE_IMAGES_PER_CHAPTER=2
DASHSCOPE_WATERMARK=true

# --------------------------------------------
# 多媒体配置
# --------------------------------------------
ENABLE_MULTIMEDIA=false
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_VOLUME=+0%
VIDEO_FPS=24
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720

# --------------------------------------------
# 记忆系统配置
# --------------------------------------------
SLIDING_WINDOW_MAX_TOKENS=2500
CONTINUITY_THRESHOLD=80.0
SUMMARY_MAX_LENGTH=100

# --------------------------------------------
# 前端配置
# --------------------------------------------
FRONTEND_PORT=8080
FRONTEND_HOST=0.0.0.0

# --------------------------------------------
# 日志配置
# --------------------------------------------
LOG_LEVEL=INFO
VERBOSE_LOG=false
