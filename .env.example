# ============================================
# 无限小说生成系统 - 环境变量配置
# ============================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入您的实际 API 密钥
# 3. 根据需要调整其他配置
# ============================================

# --------------------------------------------
# LLM 提供商选择 (v2.45 — catalog 扩展到 23 个 OpenAI 兼容 provider)
# --------------------------------------------
# 可选值: deepseek / mimo / qwen / zhipu / moonshot / baidu / ark /
#         siliconflow / stepfun / minimax / baichuan / lingyiwanwu / ai360 /
#         openai / xai / groq / openrouter / together / fireworks / mistral /
#         novita / gemini_oai / custom
# 每个 provider 的 *_API_KEY / *_BASE_URL / *_MODEL 三件套独立配, 切换 provider
# 改 LLM_PROVIDER 即可. 没填的 provider env 走 catalog default base_url / model.
# 非 OpenAI 兼容 (Anthropic Messages / Gemini 原生 / 百度文心 v1 / 腾讯混元 等)
# 走 one-api 网关 → 配 custom provider 指向 one-api endpoint.
LLM_PROVIDER=deepseek

# 通用参数（所有提供商共享，可被覆盖）
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# --------------------------------------------
# DeepSeek API 配置 (历史 default)
# --------------------------------------------
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
# 向后兼容字段（如果填了，会覆盖 LLM_* 通用参数）
DEEPSEEK_MAX_TOKENS=8192
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_TIMEOUT=120

# --------------------------------------------
# MiMo (小米) API 配置
# --------------------------------------------
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-chat

# --------------------------------------------
# 国内 OpenAI 兼容 (v2.45)
# --------------------------------------------
# 通义千问 (阿里 DashScope OpenAI 兼容模式)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# 智谱 GLM
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-plus

# Moonshot Kimi
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-32k

# 百度千帆 v2 (OpenAI 兼容)
BAIDU_API_KEY=
BAIDU_BASE_URL=https://qianfan.baidubce.com/v2
BAIDU_MODEL=ernie-4.0-turbo-128k

# 火山引擎方舟 (豆包)
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-pro-32k

# SiliconFlow (硅基流动)
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# 阶跃星辰 step
STEPFUN_API_KEY=
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_MODEL=step-1-256k

# MiniMax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5-chat

# 百川 Baichuan
BAICHUAN_API_KEY=
BAICHUAN_BASE_URL=https://api.baichuan-ai.com/v1
BAICHUAN_MODEL=Baichuan4-Turbo

# 零一万物 (Yi)
LINGYIWANWU_API_KEY=
LINGYIWANWU_BASE_URL=https://api.lingyiwanwu.com/v1
LINGYIWANWU_MODEL=yi-large

# 360 智脑
AI360_API_KEY=
AI360_BASE_URL=https://api.360.cn/v1
AI360_MODEL=360gpt-pro

# --------------------------------------------
# 海外 OpenAI 兼容 (v2.45)
# --------------------------------------------
# OpenAI 官方
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# xAI Grok
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-2-latest

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (聚合: 含 Anthropic / Gemini / Llama 等等)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Together AI
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Fireworks AI
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# Mistral La Plateforme
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-large-latest

# Novita AI
NOVITA_API_KEY=
NOVITA_BASE_URL=https://api.novita.ai/v3/openai
NOVITA_MODEL=meta-llama/llama-3.3-70b-instruct

# Google Gemini (OpenAI 兼容层 — 注意是 v1beta/openai 路径, 不是 Gemini 原生)
GEMINI_OAI_API_KEY=
GEMINI_OAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_OAI_MODEL=gemini-1.5-flash

# --------------------------------------------
# 自定义 (OpenAI 兼容) 端点 — 含 one-api 网关 / Azure / Ollama
# --------------------------------------------
# 一般用法:
#   1) one-api 网关: CUSTOM_BASE_URL=http://localhost:3000/v1 + CUSTOM_API_KEY=<one-api token>
#   2) Azure OpenAI: CUSTOM_BASE_URL=https://{resource}.openai.azure.com/openai/deployments/{deployment}/?api-version=2024-02-15-preview
#   3) Ollama:       CUSTOM_BASE_URL=http://localhost:11434/v1
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=

# --------------------------------------------
# DashScope API 配置（可选，用于图片生成）
# --------------------------------------------
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_MODEL=qwen-image-2.0
DASHSCOPE_IMAGES_PER_CHAPTER=2
DASHSCOPE_WATERMARK=true

# --------------------------------------------
# 多媒体配置
# --------------------------------------------
ENABLE_MULTIMEDIA=false
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_VOLUME=+0%
VIDEO_FPS=24
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720

# --------------------------------------------
# 记忆系统配置
# --------------------------------------------
SLIDING_WINDOW_MAX_TOKENS=2500
CONTINUITY_THRESHOLD=80.0
SUMMARY_MAX_LENGTH=100

# --------------------------------------------
# 前端配置
# --------------------------------------------
FRONTEND_PORT=8080
FRONTEND_HOST=0.0.0.0

# --------------------------------------------
# 日志配置
# --------------------------------------------
LOG_LEVEL=INFO
VERBOSE_LOG=false
